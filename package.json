{
  "name": "minions-ui",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:ui": "vite",
    "dev:server": "bun --hot run server/cli/index.ts",
    "doctor": "bun run server/cli/index.ts doctor",
    "dev": "concurrently -n ui,server -c cyan,magenta \"bun run dev:ui\" \"bun run dev:server\"",
    "dev:local": "bash scripts/dev-local.sh",
    "dev:local:engine": "bash scripts/dev-local.sh --engine",
    "dev:local:ui": "bash scripts/dev-local.sh --ui",
    "dev:local:reset": "bash scripts/dev-local.sh --reset",
    "build": "tsc -b && vite build",
    "build:ui": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "bun test server/ shared/",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps",
    "pr:create": "bash scripts/create-pr.sh",
    "format": "prettier --write .",
    "prepare": "husky || true",
    "docker:build": "docker build -f docker/engine.Dockerfile -t minions-engine ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@preact/signals": "^2.0.2",
    "@reactflow/background": "^11.3.14",
    "@reactflow/controls": "^11.2.14",
    "@reactflow/core": "^11.11.4",
    "@reactflow/minimap": "^11.7.14",
    "dagre": "^0.8.5",
    "dompurify": "^3.4.0",
    "hono": "^4.6.12",
    "idb-keyval": "^6.2.1",
    "marked": "^18.0.2",
    "mermaid": "^11.14.0",
    "preact": "^10.26.4",
    "web-push": "^3.6.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.47.0",
    "@preact/preset-vite": "^2.10.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.0.15",
    "@testing-library/preact": "^3.2.4",
    "@types/bun": "^1.1.0",
    "@types/dagre": "^0.7.52",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.14.0",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.0.0",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "prettier": "^3.3.3",
    "sharp": "^0.33.0",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.1",
    "vite": "^6.2.4",
    "vite-plugin-pwa": "^0.21.0",
    "vitest": "^4.1.0",
    "workbox-core": "^7.0.0",
    "workbox-precaching": "^7.0.0",
    "workbox-routing": "^7.0.0"
  }
}
